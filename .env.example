DB_USER=incident_user
DB_PASSWORD=change_me
DB_NAME=incident_db

# Seeded logins, created by the backend at startup if missing (see UserSeeder).
# Passwords must be 8+ chars with at least one digit and one uppercase letter.
SEED_ADMIN_EMAIL=superadmin@swam.local
SEED_ADMIN_PASSWORD=Admin1234
SEED_USER_EMAIL=user@swam.local
SEED_USER_PASSWORD=User12345
SEED_DEPT_ADMIN_EMAIL=it-admin@swam.local
SEED_DEPT_ADMIN_PASSWORD=ItAdmin123

# Signs the JWT issued on login (not yet enforced on requests — see JwtIssuer). 32+ chars.
JWT_SECRET=change_me_to_a_random_32plus_char_secret
